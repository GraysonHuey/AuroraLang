START

PUSHINT 5
PUSHINT 10
ADD
DISPLAY 5 + 10 =
DISPLAY TOP

// Empty lines for readability
DISPLAY NEWLN
DISPLAY NEWLN

PUSHINT 8
PUSHINT 16
SUB
DISPLAY 8 - 16 =
DISPLAY TOP

// Empty lines for readability
DISPLAY NEWLN
DISPLAY NEWLN

PUSHINT 12
PUSHINT 5
MUL
DISPLAY 12 * 5 =
DISPLAY TOP

// Empty lines for readability
DISPLAY NEWLN
DISPLAY NEWLN

PUSHINT 18
PUSHINT 4
DIV
DISPLAY 18 / 4 =
DISPLAY TOP


END
